# =============================================================================
# Project Recon — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================


# ── Core ─────────────────────────────────────────────────────────────────────

DEBUG=True
SECRET_KEY=django-insecure-placeholder-for-local-dev-must-be-long-enough
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated frontend origins for CORS + CSRF.
# Required (no default) when DEBUG=False.
FRONTEND_ORIGINS=http://localhost:3000


# ── Database ─────────────────────────────────────────────────────────────────
#
# DB_ENGINE options:
#   sqlite      — local file-based (easiest for development)
#   postgresql  — full PostgreSQL server

DB_ENGINE=sqlite

# If DB_ENGINE=sqlite:
#   DB_NAME — file name (relative to BASE_DIR) or absolute path
#   (default: db.sqlite3)
# DB_NAME=db.sqlite3

# If DB_ENGINE=postgresql:  (all required)
# DB_NAME=college_db
# DB_USER=college_user
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432


# ── Authentication feature flags ─────────────────────────────────────────────

AUTH_REQUIRE_EMAIL_VERIFICATION=True
AUTH_REQUIRE_DEVICE_VERIFICATION=True
AUTH_OTP_LENGTH=6
AUTH_OTP_EXPIRY_MINUTES=10
AUTH_MAX_OTP_ATTEMPTS=3
AUTH_MAX_OTP_RESENDS=3
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_ACCOUNT_LOCK_MINUTES=15

# JWT lifetimes (minutes / days)
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=1

# Throttle rates (override defaults)
# THROTTLE_LOGIN=10/min
# THROTTLE_OTP_SEND=5/hour
# THROTTLE_OTP_VERIFY=5/min
# THROTTLE_EMAIL_VERIFY=10/min
# THROTTLE_VERIFICATION_RESEND=5/hour
# THROTTLE_FORGOT_PASSWORD=3/min
# THROTTLE_RESET_PASSWORD=5/min


# ── Reports ──────────────────────────────────────────────────────────────────

REPORT_INSTITUTE_NAME=Institute


# ── Static Files ─────────────────────────────────────────────────────────────
#
# STATIC_BACKEND  storage  required env vars
# ─────────────── ───────  ───────────────────────────────────────────
# local           disk     (nothing extra — nginx/caddy serves STATIC_ROOT)
# whitenoise      disk     requires: pip install whitenoise
# s3              S3       STATIC_BUCKET_NAME or STORAGE_BUCKET_NAME + keys
# azure           Azure    STATIC_ACCOUNT_NAME / STATIC_CONTAINER_NAME + key
# gcs             GCS      STATIC_BUCKET_NAME or STORAGE_BUCKET_NAME

STATIC_BACKEND=local
STATIC_URL=/static/
# STATIC_ROOT=/absolute/path/to/staticfiles          (default: <BASE_DIR>/staticfiles)

# ── STATIC_BACKEND=whitenoise ────────────────────────────────────────────────
# No extra env vars needed. Requires `pip install whitenoise`.
# Django serves static files itself — good for Heroku / Render / Railway.

# ── STATIC_BACKEND=s3 ────────────────────────────────────────────────────────
# Requires: pip install django-storages boto3
# STATIC_BUCKET_NAME=my-bucket
# STATIC_ACCESS_KEY=AKIA...
# STATIC_SECRET_KEY=...
# STATIC_REGION=us-east-1
# STATIC_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com
# STATIC_CUSTOM_DOMAIN=static.example.com
# STATIC_LOCATION=static

# ── STATIC_BACKEND=azure ─────────────────────────────────────────────────────
# Requires: pip install django-storages azure-storage-blob
# STATIC_ACCOUNT_NAME=mystorageaccount
# STATIC_ACCOUNT_KEY=...
# STATIC_CONTAINER_NAME=static
# STATIC_CUSTOM_DOMAIN=static.example.com

# ── STATIC_BACKEND=gcs ───────────────────────────────────────────────────────
# Requires: pip install django-storages google-cloud-storage
# STATIC_BUCKET_NAME=my-bucket
# STATIC_GCS_CREDENTIALS_FILE=/path/to/service-account-key.json
# STATIC_CUSTOM_DOMAIN=static.example.com


# ── Media Files ──────────────────────────────────────────────────────────────
#
# MEDIA_BACKEND  storage  required env vars
# ────────────── ───────  ────────────────────────────────────────────
# local          disk     MEDIA_ROOT (default: <BASE_DIR>/media)
# s3             S3       STORAGE_BUCKET_NAME + keys
# azure          Azure    STORAGE_ACCOUNT_NAME / STORAGE_CONTAINER_NAME + key
# gcs            GCS      STORAGE_BUCKET_NAME

MEDIA_BACKEND=local
MEDIA_URL=/media/
# MEDIA_ROOT=/absolute/path/to/media

# ── MEDIA_BACKEND=s3 ─────────────────────────────────────────────────────────
# Requires: pip install django-storages boto3
# STORAGE_BUCKET_NAME=my-bucket
# STORAGE_ACCESS_KEY=AKIA...
# STORAGE_SECRET_KEY=...
# STORAGE_REGION=us-east-1
# STORAGE_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com
# STORAGE_CUSTOM_DOMAIN=media.example.com
# STORAGE_FILE_OVERWRITE=false
# STORAGE_DEFAULT_ACL=private
# STORAGE_QUERYSTRING_AUTH=true

# ── MEDIA_BACKEND=azure ──────────────────────────────────────────────────────
# Requires: pip install django-storages azure-storage-blob
# STORAGE_ACCOUNT_NAME=mystorageaccount
# STORAGE_ACCOUNT_KEY=...
# STORAGE_CONTAINER_NAME=media
# STORAGE_CUSTOM_DOMAIN=media.example.com
# STORAGE_USE_SSL=true

# ── MEDIA_BACKEND=gcs ────────────────────────────────────────────────────────
# Requires: pip install django-storages google-cloud-storage
# STORAGE_BUCKET_NAME=my-bucket
# STORAGE_GCS_CREDENTIALS_FILE=/path/to/service-account-key.json
# STORAGE_CUSTOM_DOMAIN=media.example.com
# STORAGE_DEFAULT_ACL=projectPrivate


# ── SSL / HTTPS ──────────────────────────────────────────────────────────────
#
# These auto-adjust based on DEBUG:
#   DEBUG=True   → all disabled (secure cookies off, HSTS 0, no redirect)
#   DEBUG=False  → all enabled  (secure cookies on, HSTS 1 year, redirect on)
#
# Override individual settings explicitly:

# SECURE_SSL_REDIRECT=false
# SESSION_COOKIE_SECURE=false
# CSRF_COOKIE_SECURE=false


# ── Email ────────────────────────────────────────────────────────────────────
#
# EMAIL_PROVIDER options:
#   console     — prints to terminal (development only)
#   smtp        — any SMTP server (MailerSend SMTP, Gmail, SES SMTP, etc.)
#   mailersend  — MailerSend API via anymail
#   sendgrid    — SendGrid API via anymail
#   postmark    — Postmark API via anymail
#   brevo       — Brevo API via anymail
#   ses         — AWS SES API via anymail (uses IAM / boto3, no API key needed)
#
# Requirements per provider:
#   console       — nothing extra
#   smtp          — SMTP_HOST + SMTP_USER + SMTP_PASSWORD
#   mailersend    — pip install django-anymail + EMAIL_API_KEY
#   sendgrid      — pip install django-anymail + EMAIL_API_KEY
#   postmark      — pip install django-anymail + EMAIL_API_KEY
#   brevo         — pip install django-anymail + EMAIL_API_KEY
#   ses           — pip install django-anymail (auth via IAM / AWS_* env vars)

EMAIL_PROVIDER=console
DEFAULT_FROM_EMAIL=noreply@localhost

# ── EMAIL_PROVIDER=console ───────────────────────────────────────────────────
# Print emails to terminal. No further config needed.
# Only suitable for local development.

# ── EMAIL_PROVIDER=smtp ──────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false

# ── EMAIL_PROVIDER=sendgrid ──────────────────────────────────────────────────
# EMAIL_API_KEY=SG.xxxxx

# ── EMAIL_PROVIDER=brevo ─────────────────────────────────────────────────────
# EMAIL_API_KEY=your-brevo-api-key

# ── EMAIL_PROVIDER=mailersend ────────────────────────────────────────────────
# EMAIL_API_KEY=mlsn.xxxxx

# ── EMAIL_PROVIDER=postmark ──────────────────────────────────────────────────
# EMAIL_API_KEY=your-postmark-server-token

# ── EMAIL_PROVIDER=ses ───────────────────────────────────────────────────────
# No EMAIL_API_KEY needed. Authenticates via IAM role or AWS_* env vars:
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# ── Email settings ───────────────────────────────────────────────────────────
# FRONTEND_VERIFY_EMAIL_URL=https://recon.app/verify-email
# EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=30
# LOGIN_OTP_TTL_MINUTES=10
